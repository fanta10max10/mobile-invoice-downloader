# ─── My SoftBank 料金明細ダウンロード 環境変数 ───
#
# このファイルを .env にコピーして値を設定してください:
#   cp env.example .env

# GoogleスプレッドシートのURL（ブラウザのアドレスバーからそのままコピーしてOK）
# 例: https://docs.google.com/spreadsheets/d/1ABC...xyz/edit?gid=0
SPREADSHEET_URL=

# PDFの保存先ベースパス (Googleドライブのローカルパス)
# 例: /Users/yamamoto/Library/CloudStorage/GoogleDrive-xxx/マイドライブ/SoftBank明細/
BASE_SAVE_PATH=

# ダウンロード対象月 (YYYYMM形式)。未指定なら前月が自動選択される
# TARGET_MONTH=202602

# ヘッドレスモード (true/false)。デバッグ時はfalseにしてブラウザを表示できる
HEADLESS=true

# セキュリティ番号入力のタイムアウト(秒)
SECURITY_CODE_TIMEOUT=300
